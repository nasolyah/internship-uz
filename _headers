# Cloudflare Pages по умолчанию отдаёт статику с cache-control: max-age=14400 —
# четыре часа. Браузер всё это время не спрашивает сервер о новой версии, поэтому
# после каждой выкладки посетители продолжали видеть старый сайт, пока не сделают
# жёсткое обновление. Имена файлов у нас без хэша, так что версию по адресу
# не различить — единственный способ, чтобы правки доезжали сразу.
#
# no-cache — это не «не хранить», а «перед использованием спроси сервер».
# С ETag ответ почти всегда 304 без тела, так что трафик и скорость не страдают.

/int_app.js
  Cache-Control: no-cache

/int_css.css
  Cache-Control: no-cache

/ai_test_bank.js
  Cache-Control: no-cache

# Шаблон согласия меняется редко, но ссылка на него обещана «в один клик» —
# пусть тоже проверяется.
/templates/*
  Cache-Control: no-cache
